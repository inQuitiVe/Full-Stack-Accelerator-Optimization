# =============================================================================
# Makefile — HDnn-PIM EDA Automation
#
# Targets:
#   synth   : Run Design Compiler synthesis (Path 2)
#   sim     : Run VCS gate-level simulation (Path 3, requires synth first)
#   power   : Run PrimeTime PX dynamic power analysis (Path 3, requires sim)
#   clean   : Remove all generated outputs
#
# IMPORTANT:
#   - Adapt DC_CMD and VCS_CMD to match your EDA tool installation paths.
#   - synth.tcl is generated at runtime by json_to_svh.py from synth_template.tcl.
#   - tb_macros.svh is generated at runtime by json_to_svh.py.
# =============================================================================

# ── Tool Paths (adapt to your environment) ────────────────────────────────────
DC_CMD    := dc_shell -f
VCS_CMD   := vcs
PT_CMD    := pt_shell -f

# ── Directories ───────────────────────────────────────────────────────────────
REPORTS_DIR := reports
VCS_DIR     := vcs
DC_DIR      := dc
DATA_DIR    := data
INCLUDE_DIR := include

# ── Generated Files ───────────────────────────────────────────────────────────
NETLIST     := $(REPORTS_DIR)/synth_netlist.v
SIMV        := simv
VCS_LOG     := $(REPORTS_DIR)/vcs_simulation.log
SAIF        := $(REPORTS_DIR)/activity.saif
PTPX_RPT    := $(REPORTS_DIR)/ptpx_power.rpt

# ── File Lists for VCS ────────────────────────────────────────────────────────
# vcs/filelist.f should list all gate-level netlist files and standard cell models.
# Create this file manually with the paths to your PDK simulation models.
VCS_FILELIST := $(VCS_DIR)/filelist.f

.PHONY: all synth sim power clean help

# ── Default Target ────────────────────────────────────────────────────────────
all: synth

help:
	@echo "Usage:"
	@echo "  make synth   - Run Design Compiler synthesis (Path 2)"
	@echo "  make sim     - Run VCS gate-level simulation (Path 3)"
	@echo "  make power   - Run PrimeTime PX power analysis (Path 3)"
	@echo "  make clean   - Remove all generated report files"

# ── Path 2: Synthesis ─────────────────────────────────────────────────────────
# Prerequisites: synth.tcl generated by json_to_svh.py
synth: $(DC_DIR)/synth.tcl $(INCLUDE_DIR)/config_macros.svh
	@echo "[Makefile] Starting Design Compiler synthesis..."
	@mkdir -p $(REPORTS_DIR)
	$(DC_CMD) $(DC_DIR)/synth.tcl 2>&1 | tee $(REPORTS_DIR)/dc_run.log
	@echo "[Makefile] Synthesis complete. Reports written to $(REPORTS_DIR)/."

# ── Path 3: Gate-Level Simulation ─────────────────────────────────────────────
# Prerequisites: synth must have produced the netlist; hex data in data/
sim: $(NETLIST) $(VCS_DIR)/tb_macros.svh
	@echo "[Makefile] Compiling gate-level netlist with VCS..."
	@mkdir -p $(REPORTS_DIR)
	$(VCS_CMD) -full64 -sverilog \
	    +define+GATE_SIM \
	    -f $(VCS_FILELIST) \
	    $(NETLIST) \
	    $(VCS_DIR)/tb_top.sv \
	    +incdir+$(INCLUDE_DIR) \
	    +incdir+$(VCS_DIR) \
	    -o $(SIMV) \
	    2>&1 | tee $(REPORTS_DIR)/vcs_compile.log
	@echo "[Makefile] Running simulation..."
	./$(SIMV) -sv_lib none 2>&1 | tee $(VCS_LOG)
	@echo "[Makefile] Simulation complete. Log: $(VCS_LOG)"

# ── Path 3: PrimeTime PX Power Analysis ──────────────────────────────────────
# Prerequisites: sim must have generated activity.saif
power: $(SAIF)
	@echo "[Makefile] Running PrimeTime PX power analysis..."
	@mkdir -p $(REPORTS_DIR)
	$(PT_CMD) $(DC_DIR)/ptpx.tcl 2>&1 | tee $(PTPX_RPT)
	@echo "[Makefile] Power analysis complete. Report: $(PTPX_RPT)"

# ── Dependency Guards ─────────────────────────────────────────────────────────
$(DC_DIR)/synth.tcl:
	@echo "[Makefile] ERROR: synth.tcl not found."
	@echo "           Run json_to_svh.py first to generate it."
	@exit 1

$(INCLUDE_DIR)/config_macros.svh:
	@echo "[Makefile] ERROR: config_macros.svh not found."
	@echo "           Run json_to_svh.py first to generate it."
	@exit 1

$(VCS_DIR)/tb_macros.svh:
	@echo "[Makefile] ERROR: vcs/tb_macros.svh not found."
	@echo "           Run json_to_svh.py first to generate it."
	@exit 1

$(NETLIST):
	@echo "[Makefile] ERROR: Netlist not found at $(NETLIST)."
	@echo "           Run 'make synth' first."
	@exit 1

$(SAIF):
	@echo "[Makefile] ERROR: SAIF not found at $(SAIF)."
	@echo "           Run 'make sim' first."
	@exit 1

# ── Clean ─────────────────────────────────────────────────────────────────────
clean:
	@echo "[Makefile] Cleaning generated files..."
	rm -rf $(REPORTS_DIR)/* $(SIMV) simv.daidir csrc \
	       $(DC_DIR)/synth.tcl \
	       $(INCLUDE_DIR)/config_macros.svh \
	       $(VCS_DIR)/tb_macros.svh \
	       $(DATA_DIR)/*.hex
	@echo "[Makefile] Clean complete."
