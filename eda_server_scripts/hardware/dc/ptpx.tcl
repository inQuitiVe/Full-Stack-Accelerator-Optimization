# =============================================================================
# ptpx.tcl — PrimeTime PX Power Analysis Script
#
# Reads the synthesized netlist and the SAIF activity file generated by VCS,
# then produces an accurate gate-level dynamic power report.
#
# IMPORTANT: Adapt library paths to your PDK.
# =============================================================================

# ── Library Setup ─────────────────────────────────────────────────────────────
set_app_var target_library "path/to/your_stdcell.db"
set_app_var link_library   "* path/to/your_stdcell.db"

# ── Read Netlist ──────────────────────────────────────────────────────────────
read_verilog reports/synth_netlist.v
link_design hdnn_top

# ── Apply Timing Constraints (same as synthesis) ──────────────────────────────
# Clock period must match the synthesis constraint for accurate hold analysis.
create_clock -period 10.0 -name clk [get_ports clk]

# ── Read Switching Activity from VCS SAIF ─────────────────────────────────────
read_saif reports/activity.saif -instance tb_top/u_dut

# ── Power Analysis ────────────────────────────────────────────────────────────
update_power
report_power > reports/ptpx_power.rpt

exit
