# =============================================================================
# Makefile — Full-Stack DSE EDA Automation
#
# Location on server: ~/workspace/full-stack-opt/Makefile
# Invoked by eda_server.py via subprocess.run(["make", "synth", "SYNTH_MODE=...", "TOP_MODULE=..."])
#
# All EDA tools are run with CWD = ../fsl-hd/ so that TCL scripts inside
# fsl-hd/tcl/ can reference RTL, libraries, and reports with short relative paths.
#
# Targets:
#   synth   : Run Design Compiler (Path 2 — PPA estimation)
#   sim     : Run VCS gate-level simulation (Path 3 — cycle-accurate metrics)
#   clean   : Remove all DSE-generated artifacts from fsl-hd/
#
# Runtime variables (passed by eda_server.py; must match between synth and sim):
#   SYNTH_MODE ?= slow     EDA synthesis mode: slow (full RTL) | fast (blackbox)
#   TOP_MODULE ?= core     Synthesis/simulation scope:
#                            core   → tb_core_timing.sv  (full wrapper)
#                            hd_top → tb_hd_top_timing.sv (HD core only)
#
# Note: Path 3 uses LFSR-based testbenches — NO hex data file transfer needed.
#
# Prerequisites (adapt to your EDA environment):
#   dc_shell, vcs must be on $PATH.
# =============================================================================

# ── Runtime Variables ─────────────────────────────────────────────────────────
# Defaults can be overridden: make sim SYNTH_MODE=fast TOP_MODULE=hd_top
SYNTH_MODE  ?= slow
TOP_MODULE  ?= hd_top

# Waveform format for VCS dump (optional).
#   vcd  (default) : standard VCD; tb uses $dumpvars (always available).
#   fsdb           : FSDB via VCS -kdb; tb uses $fsdbDumpvars (requires Verdi PLI).
DUMP_FORMAT ?= vcd

# ── Directory References (relative to this Makefile = full-stack-opt/) ────────
FSL_HD     := $(abspath ../fsl-hd)
REPORTS    := $(FSL_HD)/reports
INCLUDE    := $(FSL_HD)/verilog/include
TCL_SCRIPT := $(abspath ./dc/synth_dse.tcl)
TB_DIR     := $(FSL_HD)/verilog/tb
NETLIST    := $(REPORTS)/synth_netlist.v

# RTL and memory models needed to elaborate the synthesized netlist
HDL_DIR    := $(FSL_HD)/verilog/hdl
RF_LIB     := $(FSL_HD)/mem_rf

# ── Activity file & VCS flags based on DUMP_FORMAT ───────────────────────────
ifeq ($(DUMP_FORMAT),fsdb)
  ACTIVITY     := $(REPORTS)/activity.fsdb
  # -kdb enables Verdi database (FSDB) support; +define+DUMP_FSDB activates
  # $fsdbDumpvars in the testbench.  NOVAS_HOME must be set in the environment.
  VCS_DUMP_OPT := -kdb -debug_access+all +define+DUMP_FSDB
else
  ACTIVITY     := $(REPORTS)/activity.vcd
  VCS_DUMP_OPT :=
endif

# ── Testbench Selection based on TOP_MODULE ───────────────────────────────────
# top_module=core    → full wrapper testbench (exercises chip_interface + hd_top)
# top_module=hd_top  → HD-core-only testbench (faster, omits PatterNet path)
ifeq ($(TOP_MODULE),hd_top)
  TB_FILE := $(TB_DIR)/tb_hd_top_timing.sv
  SIM_TOP := tb_hd_top_timing
else
  TB_FILE := $(TB_DIR)/tb_core_timing.sv
  SIM_TOP := tb_core_timing
endif

# ── PatterNet & rram_wrapper (only when TOP_MODULE=core) ───────────────────────
# SYNTH_MODE=slow: full PatterNet RTL → netlist has pe, SRAMs, rram_wrapper
# SYNTH_MODE=fast: PatterNet blackbox → netlist has "top" stub + rram_wrapper
TSMC_SRAM := /opt/lib/tsmc/compiled/sram
TSMC_RF   := /opt/lib/tsmc/compiled/rf
PNET_MEMS_core := \
	$(TSMC_SRAM)/ts1n40lpb8192x16m8swba_260a/VERILOG/ts1n40lpb8192x16m8swba_260a_tt1p1v25c.v \
	$(TSMC_SRAM)/ts1n40lpb520x36m4swba_260a/VERILOG/ts1n40lpb520x36m4swba_260a_tt1p1v25c.v \
	$(TSMC_SRAM)/ts1n40lpb2048x16m8swba_260a/VERILOG/ts1n40lpb2048x16m8swba_260a_tt1p1v25c.v \
	$(TSMC_RF)/ts5n40lphsa136x16m4s_200a/VERILOG/ts5n40lphsa136x16m4s_200a_tt1p1v25c.v
RRAM_STUB_core := $(HDL_DIR)/rram_wrapper_stub.v
PE_STUB_core   := $(HDL_DIR)/pe_stub.v
TOP_PNET_STUB  := $(HDL_DIR)/top_pnet_stub.sv

# core+slow: PatterNet fully elaborated → need mems + pe + rram stubs
CORE_EXTRAS_slow := $(PNET_MEMS_core) $(RRAM_STUB_core) $(PE_STUB_core)
# core+fast: PatterNet blackbox → need top stub + rram stub only
CORE_EXTRAS_fast := $(TOP_PNET_STUB) $(RRAM_STUB_core)

# hd_top: netlist is hierarchical and references hd_enc (RTL); provide RTL for binding
HD_TOP_EXTRAS := $(HDL_DIR)/hd_enc.sv

# ── EDA Tool Commands ─────────────────────────────────────────────────────────
DC_CMD  := dc_shell -f
VCS_CMD := vcs

.PHONY: all synth sim clean help

all: synth

help:
	@echo "Usage:"
	@echo "  make synth [SYNTH_MODE=slow|fast] [TOP_MODULE=core|hd_top]"
	@echo "  make sim   [SYNTH_MODE=slow|fast] [TOP_MODULE=core|hd_top] [DUMP_FORMAT=fsdb|vcd]"
	@echo "  make clean"
	@echo ""
	@echo "  SYNTH_MODE:  slow (full RTL, default) | fast (blackbox PatterNet)"
	@echo "  TOP_MODULE:  core (full wrapper) | hd_top (HD core only, default)"
	@echo "               TOP_MODULE must match between synth and sim!"
	@echo ""
	@echo "  Path 3 testbench: $(TB_FILE)"

# ── Path 2: Synthesis ─────────────────────────────────────────────────────────
# synth_dse.tcl and config_macros.svh are generated by json_to_svh.py before this runs.
# TOP_MODULE is already baked into synth_dse.tcl by json_to_svh.py (TOP_MODULE_PLACEHOLDER).
synth: $(TCL_SCRIPT) $(INCLUDE)/config_macros.svh
	@echo "[DSE] Starting Design Compiler synthesis (SYNTH_MODE=$(SYNTH_MODE), TOP_MODULE=$(TOP_MODULE))..."
	@mkdir -p $(REPORTS)
	export SNPSLMD_LICENSE_FILE=1705@its-flexlm-lnx4.ucsd.edu && \
	cd $(FSL_HD) && $(DC_CMD) ../eda_server_scripts/dc/synth_dse.tcl 2>&1 | tee reports/dc_dse_run.log
	@echo "[DSE] Synthesis complete. Reports in $(REPORTS)/"

# ── Path 3: Gate-Level Simulation ─────────────────────────────────────────────
# Uses LFSR-based testbench; no hex data files needed.
# TB_FILE and SIM_TOP are selected based on TOP_MODULE above.
# tb_macros.svh provides TB_CLK_PERIOD_NS (written by json_to_svh.py).
#
# IMPORTANT: TOP_MODULE and SYNTH_MODE must match the netlist.
#   - synth with TOP_MODULE=core  → sim needs TOP_MODULE=core
#   - synth with TOP_MODULE=hd_top → sim needs TOP_MODULE=hd_top
#   - synth with SYNTH_MODE=slow → sim needs SYNTH_MODE=slow (full PatterNet libs)
#   - synth with SYNTH_MODE=fast → sim needs SYNTH_MODE=fast (top stub only)
#
sim: $(NETLIST) $(TB_DIR)/tb_macros.svh $(TB_FILE)
	@echo "[DSE] Path 3: Gate-level simulation (TOP_MODULE=$(TOP_MODULE), SYNTH_MODE=$(SYNTH_MODE), DUMP_FORMAT=$(DUMP_FORMAT))..."
	@mkdir -p $(REPORTS)
	cd $(FSL_HD) && $(VCS_CMD) -full64 -sverilog \
	    +define+GATE_SIM $(if $(JTAG_DEBUG),+define+JTAG_DEBUG,) \
	    $(VCS_DUMP_OPT) \
	    /opt/lib/tsmc/211005//tcbn40ulpbwp40_c170815_130d/TSMCHOME/digital/Front_End/verilog/tcbn40ulpbwp40_c170815_130a/tcbn40ulpbwp40_c170815.v \
	    $(NETLIST) \
	    verilog/hdl/sub_module.sv \
	    verilog/hdl/sram_sp_256x64.sv \
	    verilog/hdl/sram_sp_4096x64.sv \
	    verilog/hdl/rf_sp_32x32.sv \
	    $(RF_LIB)/ts1n40lpb256x32m4mwba_260a/VERILOG/ts1n40lpb256x32m4mwba_260a_tt1p1v25c.v \
	    $(RF_LIB)/ts1n40lpb4096x64m4swba_260a/VERILOG/ts1n40lpb4096x64m4swba_260a_tt1p1v25c.v \
	    $(RF_LIB)/ts5n40lphsa32x32m2s_200a/VERILOG/ts5n40lphsa32x32m2s_200a_tt1p1v25c.v \
	    $(if $(filter core,$(TOP_MODULE)),$(CORE_EXTRAS_$(SYNTH_MODE)),) \
	    $(if $(filter hd_top,$(TOP_MODULE)),$(HD_TOP_EXTRAS),) \
	    $(TB_FILE) \
	    +incdir+verilog/include \
	    +incdir+verilog/tb \
	    -top $(SIM_TOP) \
	    -o simv \
	    2>&1 | tee reports/vcs_compile.log
	@echo "[DSE] Running simulation (top=$(SIM_TOP), activity→$(ACTIVITY))..."
	cd $(FSL_HD) && ./simv 2>&1 | tee reports/vcs_simulation.log
	@echo "[DSE] Simulation complete. Activity: $(ACTIVITY)"

# ── Dependency Guards ─────────────────────────────────────────────────────────
$(TCL_SCRIPT):
	@echo "[DSE] ERROR: $(TCL_SCRIPT) not found."
	@echo "       Run json_to_svh.py first (called automatically by eda_server.py)."
	@exit 1

$(INCLUDE)/config_macros.svh:
	@echo "[DSE] ERROR: config_macros.svh not found."
	@echo "       Run json_to_svh.py first."
	@exit 1

$(TB_DIR)/tb_macros.svh:
	@echo "[DSE] ERROR: $(TB_DIR)/tb_macros.svh not found."
	@echo "       Run json_to_svh.py first (writes tb_macros.svh with TB_CLK_PERIOD_NS)."
	@exit 1

$(TB_FILE):
	@echo "[DSE] ERROR: Testbench not found at $(TB_FILE)."
	@echo "       Expected testbench for TOP_MODULE=$(TOP_MODULE)."
	@exit 1

$(NETLIST):
	@echo "[DSE] ERROR: Netlist not found at $(NETLIST)."
	@echo "       Run 'make synth' first."
	@exit 1

# ── Clean ─────────────────────────────────────────────────────────────────────
clean:
	@echo "[DSE] Removing DSE-generated artifacts from fsl-hd/..."
	rm -f  $(TCL_SCRIPT)
	rm -f  $(INCLUDE)/config_macros.svh
	rm -f  $(TB_DIR)/tb_macros.svh
	rm -rf $(REPORTS)/*
	rm -f  $(FSL_HD)/simv
	rm -rf $(FSL_HD)/simv.daidir $(FSL_HD)/csrc
	@echo "[DSE] Clean complete."
